# ── 生产环境配置 ──────────────────────────────────────────────────────
# 复制此文件为 .env.prod, 填入实际值后启动 bot:
#   NB_ENV=prod nb run --reload
# 或: python bot/bot.py

ONEBOT_WS_URLS=["ws://127.0.0.1:8080/onebot"]

# ▼ 改成你自己的 QQ 号(管理员)
SUPERUSERS=["123456789"]

# ▼ 改成你要推送的群号/好友号
GEAR_TARGET_GROUPS=["123456789"]
GEAR_TARGET_USERS=[""]

GEAR_CHECK_INTERVAL=30
LOG_LEVEL=INFO
